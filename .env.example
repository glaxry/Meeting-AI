DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

HUGGINGFACE_TOKEN=
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
VOICEPRINT_MODEL=speechbrain/spkrec-ecapa-voxceleb
VOICEPRINT_MATCH_THRESHOLD=0.65
VOICEPRINT_MIN_SEGMENT_SECONDS=0.5
VOICEPRINT_MIN_TOTAL_SECONDS=1.5
SENTIMENT_TRANSFORMER_MODEL=lxyuan/distilbert-base-multilingual-cased-sentiments-student
EMBEDDING_MODEL=intfloat/multilingual-e5-small

FUNASR_MODEL=iic/SenseVoiceSmall
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc-c
FUNASR_HUB=ms
FUNASR_STREAMING_MODEL=paraformer-zh-streaming
FUNASR_STREAMING_CHUNK_SIZE=0,10,5
FUNASR_STREAMING_ENCODER_CHUNK_LOOK_BACK=4
FUNASR_STREAMING_DECODER_CHUNK_LOOK_BACK=1
STREAMING_TARGET_SAMPLE_RATE=16000
STREAMING_GRADIO_CHUNK_SECONDS=2.0

USE_GPU=true
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.5
SUMMARY_MAP_REDUCE_THRESHOLD=500
SUMMARY_CHUNK_TARGET_WORDS=350
RETRIEVAL_CHUNK_SIZE=20
RETRIEVAL_STRATEGY=hybrid
RETRIEVAL_DENSE_CANDIDATE_K=12
RETRIEVAL_SPARSE_CANDIDATE_K=12
RETRIEVAL_RRF_K=60
RETRIEVAL_ENABLE_RERANKER=true
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_RERANKER_CANDIDATE_K=8
SENTIMENT_TIMELINE_WINDOW_SECONDS=120
CHROMA_PERSIST_DIR=data/chroma
VOICEPRINT_DIR=data/voiceprints
VOICEPRINT_MODEL_CACHE_DIR=data/voiceprints/_model_cache
MEETING_AI_API_BASE_URL=http://127.0.0.1:8000
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
